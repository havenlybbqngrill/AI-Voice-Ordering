<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Outwater Grill — Kitchen Display</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --red:#e8192c; --red-dark:#b5121f; --bg:#f5f5f5;
  --white:#fff; --dark:#1a1a1a; --gray:#6b7280;
  --light:#f9fafb; --border:#e5e7eb;
  --green:#16a34a; --orange:#ea580c;
  --shadow:0 2px 12px rgba(0,0,0,0.08);
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--dark);min-height:100vh}
.nav{background:var(--red);padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:60px;box-shadow:0 2px 8px rgba(232,25,44,0.3)}
.nav-logo{font-family:'Bebas Neue',sans-serif;font-size:26px;color:#fff;letter-spacing:0.1em}
.nav-logo span{color:#ffd700}
.nav-tabs{display:flex;gap:4px}
.nav-tab{padding:8px 16px;border-radius:8px;border:none;background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.8);font-family:'Nunito',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all 0.2s}
.nav-tab:hover{background:rgba(255,255,255,0.25);color:#fff}
.nav-tab.active{background:#fff;color:var(--red)}
.ws-status{font-size:11px;color:rgba(255,255,255,0.7);display:flex;align-items:center;gap:6px}
.ws-dot{width:8px;height:8px;border-radius:50%;background:#ef4444}
.ws-dot.connected{background:#22c55e;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}

.page{display:none;padding:24px;max-width:1400px;margin:0 auto}
.page.active{display:block}

/* KDS */
.kds-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}
.kds-title{font-family:'Bebas Neue',sans-serif;font-size:32px;letter-spacing:0.08em}
.kds-stats{display:flex;gap:12px}
.kds-stat{background:var(--white);border-radius:12px;padding:12px 20px;text-align:center;box-shadow:var(--shadow);min-width:90px}
.kds-stat-num{font-size:24px;font-weight:800}
.kds-stat-label{font-size:11px;color:var(--gray);text-transform:uppercase;letter-spacing:0.06em}
.kds-stat.new .kds-stat-num{color:var(--red)}
.kds-stat.prep .kds-stat-num{color:var(--orange)}
.kds-stat.ready .kds-stat-num{color:var(--green)}
.kds-columns{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
.kds-col-title{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:0.08em;padding:10px 16px;border-radius:10px;margin-bottom:12px;display:flex;align-items:center;gap:8px}
.kds-col-title.new{background:#fff5f5;color:var(--red)}
.kds-col-title.prep{background:#fff8f0;color:var(--orange)}
.kds-col-title.ready{background:#f0faf4;color:var(--green)}
.kds-col-dot{width:10px;height:10px;border-radius:50%}
.kds-col-title.new .kds-col-dot{background:var(--red);animation:blink 1s infinite}
.kds-col-title.prep .kds-col-dot{background:var(--orange)}
.kds-col-title.ready .kds-col-dot{background:var(--green)}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.3}}
.kds-card{background:var(--white);border-radius:14px;padding:16px;box-shadow:var(--shadow);margin-bottom:12px;border-left:4px solid transparent;animation:fadeUp 0.4s ease}
.kds-card.new{border-left-color:var(--red)}
.kds-card.prep{border-left-color:var(--orange)}
.kds-card.ready{border-left-color:var(--green)}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.kds-card-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px}
.kds-order-num{font-family:'Bebas Neue',sans-serif;font-size:24px;color:var(--dark);letter-spacing:0.06em}
.kds-time{font-size:11px;color:var(--gray);background:var(--light);padding:3px 8px;border-radius:100px}
.kds-customer{font-size:13px;font-weight:700;color:var(--red);margin-bottom:8px}
.kds-item{font-size:13px;padding:4px 0;border-bottom:1px solid var(--border)}
.kds-item:last-child{border-bottom:none}
.kds-item-name{font-weight:700}
.kds-item-custom{font-size:11px;color:var(--gray)}
.kds-total{font-size:13px;font-weight:800;margin:10px 0}
.kds-actions{display:flex;flex-direction:column;gap:8px}
.kds-btn{padding:10px;border:none;border-radius:8px;font-family:'Nunito',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all 0.2s;width:100%}
.kds-btn.red{background:var(--red);color:#fff}
.kds-btn.red:hover{background:var(--red-dark)}
.kds-btn.orange{background:var(--orange);color:#fff}
.kds-btn.orange:hover{background:#c2410c}
.kds-btn.green{background:var(--green);color:#fff}
.kds-btn.green:hover{background:#15803d}
.kds-notify{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:10px;font-size:12px;color:var(--green);font-weight:600;margin-top:6px}
.empty-col{text-align:center;padding:30px 0;color:var(--gray);font-size:13px}

/* Customers */
.history-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}
.history-title{font-family:'Bebas Neue',sans-serif;font-size:32px;letter-spacing:0.08em}
.h-input{padding:10px 16px;border:2px solid var(--border);border-radius:10px;font-family:'Nunito',sans-serif;font-size:14px;outline:none;width:240px;transition:border-color 0.2s}
.h-input:focus{border-color:var(--red)}
.customers-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px}
.customer-card{background:var(--white);border-radius:14px;padding:20px;box-shadow:var(--shadow);border:2px solid var(--border);transition:all 0.2s}
.customer-card:hover{border-color:var(--red)}
.cc-header{display:flex;gap:12px;align-items:center;margin-bottom:14px}
.cc-avatar{width:44px;height:44px;background:var(--red);border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:18px;color:#fff}
.cc-name{font-size:16px;font-weight:800}
.cc-phone{font-size:12px;color:var(--gray)}
.cc-stats{display:flex;gap:10px;margin-bottom:14px}
.cc-stat{flex:1;background:var(--light);border-radius:8px;padding:8px;text-align:center}
.cc-stat-n{font-size:18px;font-weight:800;color:var(--red)}
.cc-stat-l{font-size:10px;color:var(--gray);text-transform:uppercase;letter-spacing:0.06em}
.cc-fav{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid var(--border);font-size:12px}
.cc-fav:last-child{border-bottom:none}
.cc-fav-num{width:20px;height:20px;background:var(--red);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;flex-shrink:0}
.cc-fav-name{flex:1;font-weight:600}
.cc-fav-cnt{color:var(--gray);font-size:11px}
.cc-favs-title{font-size:11px;font-weight:700;color:var(--gray);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:8px}

.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--dark);color:#fff;border-radius:100px;padding:12px 24px;font-size:13px;font-weight:600;transition:transform 0.35s cubic-bezier(.34,1.56,.64,1);z-index:300;white-space:nowrap}
.toast.show{transform:translateX(-50%) translateY(0)}
.toast.success{background:var(--green)}

@media(max-width:900px){.kds-columns{grid-template-columns:1fr}}
</style>
</head>
<body>
<nav class="nav">
  <div class="nav-logo">OUTWATER <span>GRILL</span></div>
  <div style="display:flex;align-items:center;gap:16px">
    <div class="ws-status"><div class="ws-dot" id="wsDot"></div><span id="wsLabel">Connecting...</span></div>
    <div class="nav-tabs">
      <button class="nav-tab active" onclick="showPage('kds',this)">🍳 Kitchen</button>
      <button class="nav-tab" onclick="showPage('customers',this)">👥 Customers</button>
    </div>
  </div>
</nav>

<!-- KDS -->
<div class="page active" id="page-kds">
  <div class="kds-header">
    <div class="kds-title">KITCHEN DISPLAY</div>
    <div class="kds-stats">
      <div class="kds-stat new"><div class="kds-stat-num" id="statNew">0</div><div class="kds-stat-label">New</div></div>
      <div class="kds-stat prep"><div class="kds-stat-num" id="statPrep">0</div><div class="kds-stat-label">Preparing</div></div>
      <div class="kds-stat ready"><div class="kds-stat-num" id="statReady">0</div><div class="kds-stat-label">Ready</div></div>
    </div>
  </div>
  <div class="kds-columns">
    <div><div class="kds-col-title new"><div class="kds-col-dot"></div>NEW ORDERS</div><div id="kdsNew"></div></div>
    <div><div class="kds-col-title prep"><div class="kds-col-dot"></div>PREPARING</div><div id="kdsPrep"></div></div>
    <div><div class="kds-col-title ready"><div class="kds-col-dot"></div>READY FOR PICKUP</div><div id="kdsReady"></div></div>
  </div>
</div>

<!-- Customers -->
<div class="page" id="page-customers">
  <div class="history-header">
    <div class="history-title">CUSTOMER PROFILES</div>
    <input class="h-input" id="custSearch" placeholder="Search by name or phone..." oninput="renderCustomers()">
  </div>
  <div class="customers-grid" id="customersGrid"></div>
</div>

<div class="toast" id="toast"></div>

<script>
let orders = [];
let customers = [];
let ws;

function showPage(p, btn) {
  document.querySelectorAll('.page').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(el => el.classList.remove('active'));
  document.getElementById('page-' + p).classList.add('active');
  btn.classList.add('active');
  if (p === 'customers') loadCustomers();
}

// WebSocket connection
function connectWS() {
  const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
  ws = new WebSocket(`${proto}//${location.host}`);

  ws.onopen = () => {
    document.getElementById('wsDot').className = 'ws-dot connected';
    document.getElementById('wsLabel').textContent = 'Live';
  };

  ws.onclose = () => {
    document.getElementById('wsDot').className = 'ws-dot';
    document.getElementById('wsLabel').textContent = 'Reconnecting...';
    setTimeout(connectWS, 3000);
  };

  ws.onmessage = e => {
    const data = JSON.parse(e.data);
    if (data.type === 'init') {
      orders = data.orders;
      renderKDS();
    } else if (data.type === 'new_order') {
      orders.push(data.order);
      renderKDS();
      showToast('🔔 New order ' + data.order.id + ' from ' + data.order.customer, true);
      playBell();
    } else if (data.type === 'order_updated') {
      const idx = orders.findIndex(o => o.num === data.order.num);
      if (idx >= 0) orders[idx] = data.order;
      renderKDS();
    } else if (data.type === 'order_removed') {
      orders = orders.filter(o => o.num !== data.num);
      renderKDS();
    }
  };
}

function advanceOrder(num) {
  if (ws && ws.readyState === WebSocket.OPEN) {
    ws.send(JSON.stringify({ type: 'advance_order', num }));
  }
}

function renderKDS() {
  const cols = { new: 'kdsNew', prep: 'kdsPrep', ready: 'kdsReady' };
  Object.values(cols).forEach(id => document.getElementById(id).innerHTML = '');
  let counts = { new: 0, prep: 0, ready: 0 };

  if (!orders.length) {
    Object.values(cols).forEach(id => document.getElementById(id).innerHTML = '<div class="empty-col">No orders yet</div>');
  } else {
    orders.forEach(o => {
      counts[o.status] = (counts[o.status] || 0) + 1;
      const col = cols[o.status];
      if (!col) return;
      const el = document.createElement('div');
      el.className = 'kds-card ' + o.status;
      const btns = {
        new: `<button class="kds-btn red" onclick="advanceOrder(${o.num})">▶ Start Preparing</button>`,
        prep: `<button class="kds-btn orange" onclick="advanceOrder(${o.num})">✓ Mark Ready</button>`,
        ready: `
          <button class="kds-btn green" onclick="advanceOrder(${o.num})">✓ Complete & Remove</button>
          <div class="kds-notify">📱 Text ${o.customer}: "Your order ${o.id} is ready for pickup at Outwater Grill!"</div>
        `
      };
      el.innerHTML = `
        <div class="kds-card-header">
          <div class="kds-order-num">${o.id}</div>
          <div class="kds-time">${o.timeStr}</div>
        </div>
        <div class="kds-customer">👤 ${o.customer} · ${o.phone}</div>
        <div>
          ${o.items.map(i => `
            <div class="kds-item">
              <div class="kds-item-name">${i.qty}× ${i.name}</div>
              ${i.note ? `<div class="kds-item-custom">${i.note}</div>` : ''}
            </div>
          `).join('')}
        </div>
        <div class="kds-total">Total: $${o.total.toFixed(2)}</div>
        <div class="kds-actions">${btns[o.status] || ''}</div>
      `;
      document.getElementById(col).appendChild(el);
    });
  }

  document.getElementById('statNew').textContent = counts.new || 0;
  document.getElementById('statPrep').textContent = counts.prep || 0;
  document.getElementById('statReady').textContent = counts.ready || 0;
}

async function loadCustomers() {
  const res = await fetch('/api/customers');
  customers = await res.json();
  renderCustomers();
}

function renderCustomers() {
  const q = (document.getElementById('custSearch').value || '').toLowerCase();
  const filtered = customers.filter(c =>
    c.name.toLowerCase().includes(q) || c.phone.includes(q)
  );
  const grid = document.getElementById('customersGrid');
  if (!filtered.length) { grid.innerHTML = '<p style="color:#6b7280">No customers found.</p>'; return; }
  grid.innerHTML = filtered.map(c => `
    <div class="customer-card">
      <div class="cc-header">
        <div class="cc-avatar">${c.name.charAt(0)}</div>
        <div><div class="cc-name">${c.name}</div><div class="cc-phone">${c.phone}</div></div>
      </div>
      <div class="cc-stats">
        <div class="cc-stat"><div class="cc-stat-n">${c.orders}</div><div class="cc-stat-l">Orders</div></div>
        <div class="cc-stat"><div class="cc-stat-n">$${c.spent.toFixed(0)}</div><div class="cc-stat-l">Spent</div></div>
        <div class="cc-stat"><div class="cc-stat-n">${c.favorites.length}</div><div class="cc-stat-l">Fav Items</div></div>
      </div>
      ${c.favorites.length ? `
        <div class="cc-favs-title">⭐ Top ${Math.min(5, c.favorites.length)} Favorites</div>
        ${c.favorites.slice(0, 5).map((f, i) => `
          <div class="cc-fav">
            <div class="cc-fav-num">${i + 1}</div>
            <div class="cc-fav-name">${f.name}</div>
            <div class="cc-fav-cnt">×${f.count}</div>
          </div>
        `).join('')}
      ` : '<div style="font-size:12px;color:#6b7280">No orders yet</div>'}
    </div>
  `).join('');
}

function playBell() {
  try {
    const ctx = new AudioContext();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain); gain.connect(ctx.destination);
    osc.frequency.value = 880;
    gain.gain.setValueAtTime(0.3, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.8);
    osc.start(); osc.stop(ctx.currentTime + 0.8);
  } catch(e) {}
}

function showToast(msg, success = true) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (success ? ' success' : '');
  setTimeout(() => t.className = 'toast', 3000);
}

connectWS();
</script>
</body>
</html>
